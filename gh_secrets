# GitHub Actions Secrets — 로컬 테스트/참고용 템플릿
#
# ⚠️ 이 파일에 실제 값을 적더라도 git에 커밋하지 마세요.
#    이 파일은 빈 템플릿으로 1회 커밋된 뒤 .gitignore에 등록되어 추적이 중단됩니다.
#    (실제 값 입력은 본인 로컬에서만)
#
# 등록 방법 A) gh CLI — 값은 프롬프트로 입력(파일에 안 남김):
#   gh secret set <NAME> --repo <owner>/auth-common
# 등록 방법 B) GitHub 웹 UI:
#   레포 → Settings → Secrets and variables → Actions → New repository secret

# ── Docker Hub (이미지 빌드·푸시) ──
DOCKERHUB_USERNAME=
DOCKERHUB_TOKEN=
DOCKERHUB_NAMESPACE=

# ── 배포 서버 (SSH) ──
DEPLOY_HOST=
DEPLOY_USER=
DEPLOY_PASSWORD=
DEPLOY_PATH=
